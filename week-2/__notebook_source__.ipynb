### PHASE 3B: LAG FEATURES AND ROLLING STATISTICS

# Proper sorting before lag creation

df_fe = df_fe.sort_values(
    ['Region', 'Model', 'Date']
).reset_index(drop=True)

df_fe.head()


# Lag features

lag_features = [1, 2, 3, 6, 12]

group_cols = ['Region', 'Model']

for lag in lag_features:
    
    df_fe[f'Deliveries_Lag_{lag}'] = (
        df_fe.groupby(group_cols)['Estimated_Deliveries']
        .shift(lag)
    )

df_fe.head(15)


# Rolling mean features

rolling_windows = [3, 6]

for window in rolling_windows:
    
    df_fe[f'Rolling_Mean_{window}'] = (
        df_fe.groupby(group_cols)['Estimated_Deliveries']
        .transform(
            lambda x: x.shift(1).rolling(window).mean()
        )
    )

df_fe.head(15)


# Rolling std features

for window in rolling_windows:
    
    df_fe[f'Rolling_Std_{window}'] = (
