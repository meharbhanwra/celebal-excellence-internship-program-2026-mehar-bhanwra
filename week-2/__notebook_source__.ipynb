### PHASE 3A: TEMPORAL AND CYCLICAL FEATURES

# Copy dataframe for feature engineering

df_fe = df.copy()

print(df_fe.shape)

df_fe.head()


# Quarter feature

df_fe['Quarter'] = (
    (df_fe['Month'] - 1) // 3
) + 1


# Month start/end flags

df_fe['Is_Year_Start'] = (
    df_fe['Month'] == 1
).astype(int)

df_fe['Is_Year_End'] = (
    df_fe['Month'] == 12
).astype(int)


# Cyclical quarter position

df_fe['Quarter_Sin'] = np.sin(
    2 * np.pi * df_fe['Quarter'] / 4
)

df_fe['Quarter_Cos'] = np.cos(
    2 * np.pi * df_fe['Quarter'] / 4
)

df_fe.head()


# Cyclical month encoding

df_fe['Month_Sin'] = np.sin(
    2 * np.pi * df_fe['Month'] / 12
)

df_fe['Month_Cos'] = np.cos(
    2 * np.pi * df_fe['Month'] / 12
)

df_fe[['Month', 'Month_Sin', 'Month_Cos']].head(12)


# Correct time index creation

date_order = {
    date: idx
    for idx, date in enumerate(
        sorted(df_fe['Date'].unique())
    )
}

df_fe['Time_Index'] = (
    df_fe['Date']
    .map(date_order)
)

df_fe[['Date', 'Time_Index']].head(25)


# Relative year

df_fe['Year_Offset'] = (
    df_fe['Year'] - df_fe['Year'].min()
)

df_fe[['Year', 'Year_Offset']].head()


# Inspect engineered features

new_features = [
    'Quarter',
    'Is_Year_Start',
    'Is_Year_End',
    'Quarter_Sin',
    'Quarter_Cos',
    'Month_Sin',
    'Month_Cos',
    'Time_Index',
    'Year_Offset'
]

df_fe[new_features].describe()


# Correlations with target

engineered_corr = (
    df_fe[
        new_features + ['Estimated_Deliveries']
    ]
    .corr()['Estimated_Deliveries']
    .sort_values(ascending=False)
)

engineered_corr


